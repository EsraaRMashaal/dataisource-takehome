APP_ENV=local
PORT=8800
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]

# Database
SQLITE_DB_PATH=/app/data/DataISource-takehome.sqlite3

# GDELT monitoring
# Comma-separated list of topics sampled randomly on each poll run.
# 3 topics are chosen per run (TOPICS_PER_POLL in gdelt_service.py).
MONITOR_SOURCE=gdelt
GDELT_QUERY=shipping delays,factory shutdown,steel shortage,logistics crisis,port congestion,freight disruption,raw material shortage,manufacturing delays,transport strike,industrial shutdown
POLL_INTERVAL_SECONDS=300

# Confidence scoring weights (must sum to 1.0)
CONFIDENCE_WEIGHT_PATTERN=0.5
CONFIDENCE_WEIGHT_VALIDATION=0.3
CONFIDENCE_WEIGHT_CONTEXT=0.2
